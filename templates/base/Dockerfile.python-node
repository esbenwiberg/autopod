FROM python:3.12-slim

# System deps + Node.js 22
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    gnupg \
    locales \
    iptables haproxy socat \
    sqlite3 \
    ripgrep \
    tmux \
    build-essential \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen \
    && locale-gen \
    && rm -rf /var/lib/apt/lists/*

# Glow — terminal markdown viewer from Charm
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://repo.charm.sh/apt/gpg.key | gpg --dearmor -o /etc/apt/keyrings/charm.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" > /etc/apt/sources.list.d/charm.list \
    && apt-get update && apt-get install -y --no-install-recommends glow \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8
ENV PYTHONUNBUFFERED=1

# uv — fast Python package manager
RUN pip install --no-cache-dir uv pytest

# Create non-root user
RUN groupadd --gid 1000 autopod && \
    useradd --uid 1000 --gid autopod --shell /bin/bash --create-home autopod

# Global Node tools
RUN npm install -g pnpm@9

# Agent CLIs
RUN npm install -g @anthropic-ai/claude-code @openai/codex@0.144.4 @github/copilot @earendil-works/pi-coding-agent@0.80.6

# Trusted Autopod Pi worker extension
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml /opt/autopod/
COPY tsconfig.base.json /opt/autopod/tsconfig.base.json
COPY packages/pi-worker/package.json /opt/autopod/packages/pi-worker/package.json
COPY packages/pi-worker/tsconfig.json /opt/autopod/packages/pi-worker/tsconfig.json
COPY packages/pi-worker/src /opt/autopod/packages/pi-worker/src
RUN cd /opt/autopod \
    && pnpm --filter @autopod/pi-worker install --frozen-lockfile \
    && pnpm --filter @autopod/pi-worker build \
    && cd /opt/autopod/packages/pi-worker \
    && npm install -g . \
    && test -x /usr/local/bin/pi \
    && test -f /usr/local/lib/node_modules/@autopod/pi-worker/dist/index.js \
    && rm -rf node_modules /root/.npm

# Working directory
WORKDIR /workspace
RUN chown autopod:autopod /workspace

USER autopod

# pip --user is the only install location available to the non-root agent —
# put its bin dir on PATH so user-installed CLIs (alembic, pytest plugins, etc.)
# are reachable from the validator's non-interactive `sh -c` exec.
ENV PATH="/home/autopod/.local/bin:$PATH"

ENV TURBO_CACHE_DIR=/tmp/.turbo
ENV npm_config_nodedir=/usr/local
RUN echo "nodedir=/usr/local" >> /home/autopod/.npmrc

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT:-3000}/health || exit 1
