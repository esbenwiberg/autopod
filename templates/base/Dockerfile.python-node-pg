FROM python:3.12-slim

# System deps + Node.js 22 + PostgreSQL 17
# postgresql-17 + postgresql-contrib-17 give us the server binaries (initdb, pg_ctl,
# postgres) so agent-serve.sh-style scripts can spin up a transient validation DB.
# Pinned to 17 because it's trixie's default (python:3.12-slim is now trixie-based);
# the PATH below references the version directory — bumping requires updating both lines together.
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    gnupg \
    locales \
    iptables ipset dnsmasq \
    sqlite3 \
    tmux \
    build-essential \
    postgresql-17 \
    postgresql-contrib-17 \
    && curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && sed -i '/en_US.UTF-8/s/^# //g' /etc/locale.gen \
    && locale-gen \
    && rm -rf /var/lib/apt/lists/*

# Glow — terminal markdown viewer from Charm
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://repo.charm.sh/apt/gpg.key | gpg --dearmor -o /etc/apt/keyrings/charm.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *" > /etc/apt/sources.list.d/charm.list \
    && apt-get update && apt-get install -y --no-install-recommends glow \
    && rm -rf /var/lib/apt/lists/*

ENV LANG=en_US.UTF-8
ENV PYTHONUNBUFFERED=1

# uv — fast Python package manager
RUN pip install --no-cache-dir uv pytest

# Create non-root user
RUN groupadd --gid 1000 autopod && \
    useradd --uid 1000 --gid autopod --shell /bin/bash --create-home autopod

# Global Node tools
RUN npm install -g pnpm@9

# Agent CLIs
RUN npm install -g @anthropic-ai/claude-code @github/copilot

# Pre-install Playwright + Chromium so the agent can self-validate via the
# validate_in_browser MCP tool. `playwright install --with-deps` pulls the full
# set of OS packages Chromium needs — don't hand-pick them. Must run as root
# (still implicit here) so apt-get can install browser system deps.
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
RUN npm install -g playwright && \
    playwright install --with-deps chromium && \
    chmod -R 755 /opt/pw-browsers

# Working directory
WORKDIR /workspace
RUN chown autopod:autopod /workspace

USER autopod

# Postgres server binaries live under /usr/lib/postgresql/<ver>/bin on Debian,
# not /usr/bin — without this addition initdb/pg_ctl/postgres aren't on PATH.
# PGDATA defaults to a tmp dir so an agent's agent-serve.sh can `initdb -D $PGDATA`
# and `pg_ctl -D $PGDATA start` without writing into the image layer or /workspace.
ENV PATH="/usr/lib/postgresql/17/bin:$PATH"
ENV PGDATA=/tmp/pgdata

# Allow bare imports of globally installed packages (e.g. playwright in validation
# scripts). Debian's apt-packaged nodejs lives at /usr/lib/node_modules with
# headers under /usr/include/node — NOT /usr/local/* like the upstream node:slim
# images. node22-pw's NODE_PATH=/usr/local/* would silently break here.
ENV NODE_PATH=/usr/lib/node_modules
ENV TURBO_CACHE_DIR=/tmp/.turbo
ENV npm_config_nodedir=/usr
RUN echo "nodedir=/usr" >> /home/autopod/.npmrc

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT:-3000}/health || exit 1
