FROM node:22-slim

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    iptables ipset dnsmasq \
    tmux \
    python3 build-essential \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user — remove the default node user (uid 1000) first
RUN userdel --remove node 2>/dev/null; groupdel node 2>/dev/null; \
    groupadd --gid 1000 autopod && \
    useradd --uid 1000 --gid autopod --shell /bin/bash --create-home autopod

# Global tools
RUN npm install -g pnpm@9

# Agent CLIs
RUN npm install -g @anthropic-ai/claude-code @github/copilot

# Working directory
WORKDIR /workspace
RUN chown autopod:autopod /workspace

USER autopod

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT:-3000}/health || exit 1
