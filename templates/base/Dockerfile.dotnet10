FROM mcr.microsoft.com/dotnet/sdk:10.0

# System deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    curl \
    ca-certificates \
    iptables \
    && rm -rf /var/lib/apt/lists/*

# Node.js 22 (for npm frontend builds)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user (GID 1000 may already exist in the base image)
RUN groupadd --gid 1000 autopod 2>/dev/null || groupmod -n autopod "$(getent group 1000 | cut -d: -f1)" && \
    useradd --uid 1000 --gid autopod --shell /bin/bash --create-home autopod 2>/dev/null || usermod -l autopod -d /home/autopod -m "$(getent passwd 1000 | cut -d: -f1)"

# Agent CLIs
RUN npm install -g @anthropic-ai/claude-code @github/copilot

# Pre-warm NuGet cache with common restore patterns
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1
ENV DOTNET_NOLOGO=1

# Working directory
WORKDIR /workspace
RUN chown autopod:autopod /workspace

USER autopod

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD curl -f http://localhost:${PORT:-3000}/health || exit 1
