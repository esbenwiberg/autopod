{
  "name": "@autopod/daemon",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "dev": "tsup --watch --onSuccess 'cp -r src/db/migrations dist/db/ && mkdir -p dist/actions && cp -r src/actions/defaults dist/actions/ && node dist/index.js'",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@autopod/escalation-mcp": "workspace:^",
    "@autopod/shared": "workspace:*",
    "@autopod/validator": "workspace:*",
    "@azure/arm-containerinstance": "^9.1.0",
    "@azure/container-registry": "^1.1.0",
    "@azure/identity": "^4.6.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/websocket": "^11.2.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.7.0",
    "cron-parser": "^4.9.0",
    "dockerode": "^4.0.4",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "slugify": "^1.6.8",
    "tar-stream": "^3.1.7",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^3.3.34",
    "@types/node": "^22.10.0",
    "@types/tar-stream": "^3.1.3",
    "@types/ws": "^8.18.1",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
